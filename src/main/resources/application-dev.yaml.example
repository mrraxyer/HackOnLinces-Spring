gspring:
  datasource:
    url: ${DB_URL:jdbc:postgresql://localhost:5432/HackOnLinces}
    username: ${DB_USERNAME:postgres}
    password: ${DB_PASSWORD:postgres}
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate:
      ddl-auto: update        # Ajusta el schema sin borrar datos
    show-sql: true            # Muestra las queries en consola (útil en dev)

  # OAuth2 Google — en dev usa credenciales de tu proyecto en Google Cloud Console
  security:
    oauth2:
      client:
        registration:
          google:
            client-id: ${GOOGLE_CLIENT_ID:tu-client-id-aqui}
            client-secret: ${GOOGLE_CLIENT_SECRET:tu-client-secret-aqui}
            scope:
              - email
              - profile

# En dev mostramos todos los detalles del health check
management:
  endpoint:
    health:
      show-details: always

# Swagger activo en dev
springdoc:
  swagger-ui:
    path: /swagger-ui.html
  api-docs:
    path: /v3/api-docs

logging:
  level:
    mx.itcelaya.hackonlinces: DEBUG
    org.springframework.security: DEBUG
    org.hibernate.SQL: DEBUG
    org.hibernate.type.descriptor.sql: TRACE