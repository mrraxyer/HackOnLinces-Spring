# =============================================================================
# PLANTILLA DE VARIABLES DE ENTORNO — HackOnLinces
# Copia este archivo y renómbralo a .env para desarrollo local.
# En Dokploy estas variables se configuran directamente en el panel.
# =============================================================================

# ── Base de datos ─────────────────────────────────────────────────────────────
POSTGRES_DB=HackOnLinces
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia_esta_password

# ── Spring Boot ───────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
PORT=8080

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera un secreto seguro de mínimo 256 bits:
# openssl rand -hex 32
JWT_SECRET=cambia_este_secreto_minimo_256_bits
JWT_EXPIRATION=86400000

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Obtén estas credenciales en https://console.cloud.google.com
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local: incluye los puertos del frontend
# Producción: usa el dominio real, ej: https://app.tudominio.com
# puerto 8080 habilitado para el swagger
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080 
